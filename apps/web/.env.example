# ─── API Configuration ─────────────────────────────────────────────
# Required: Backend API URL
VITE_API_URL=http://localhost:3001

# ─── Google OAuth ──────────────────────────────────────────────────
# Required for Google Sign-In feature
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Required on API side for token validation (must match VITE_GOOGLE_CLIENT_ID)
# This ensures tokens are issued for your application
VITE_GOOGLE_CLIENT_ID_SECRET=your-google-client-id.apps.googleusercontent.com

# ─── Cloudflare Turnstile ──────────────────────────────────────────
# Required for bot protection on forms
# Get from: https://www.cloudflare.com/application-services/products/turnstile/
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ─── Environment ───────────────────────────────────────────────────
# Optional: Set to 'production' in production builds
VITE_APP_ENV=development

# ─── Site Configuration ────────────────────────────────────────────
# Optional: Site URL for SEO and meta tags (default: http://localhost:5173)
VITE_SITE_URL=http://localhost:5173
