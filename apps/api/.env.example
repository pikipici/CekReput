# ─── Database ──────────────────────────────────────────────────────
# Required: PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cekreput

# ─── JWT Secrets ───────────────────────────────────────────────────
# Required: Use strong random strings in production (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=your-super-secret-access-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here

# Optional: Token expiration (defaults shown)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudflare R2 (File Storage) ─────────────────────────────────
# Required for file uploads (evidence, profile pictures, etc.)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=cekreput-evidence
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── Redis (Rate Limiting & Caching) ──────────────────────────────
# Required for production rate limiting (in-memory used as fallback)
REDIS_URL=redis://localhost:6379

# ─── Cloudflare Turnstile (Anti-Bot) ──────────────────────────────
# Required for bot protection on forms
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ─── SMTP Configuration (Nodemailer) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Google OAuth ──────────────────────────────────────────────────
# Required for Google Sign-In token validation
# Must match the client ID used on the frontend
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Server ────────────────────────────────────────────────────────
# Optional: Server port (default: 3001)
PORT=3001

# ─── Environment ───────────────────────────────────────────────────
# Optional: Set to 'production' in production environments
NODE_ENV=development
